# Memoria configuration template.
# Copy to .env and fill in the credentials you have. Missing values
# disable the corresponding layer gracefully.

# --- Local (no config needed, paths are auto-created) ---
# Memoria lives at ~/memoria/data/. Override only if you must:
# MEMORIA_HOME=/home/ubuntu/memoria

# --- Redis (optional hot cache) ---
# Enable this only if you have a Redis instance reachable.
# Local: leave REDIS_HOST=127.0.0.1 and start redis-server.
# Upstash free tier: paste the REST URL + token.
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_HOT=3600
# REDIS_URL=rediss://default:***@***.upstash.io:6379

# --- Supabase (optional durable backup) ---
# Create a free project at https://supabase.com (500MB database).
# Run schema.sql in the Supabase SQL Editor to create tables.
SUPABASE_ENABLED=false
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Cloudflare R2 (optional cold archive) ---
# Create a free R2 bucket at https://dash.cloudflare.com (10GB free).
# Generate an API token with object read/write scope.
R2_ENABLED=false
R2_ACCOUNT_ID=YOUR_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
R2_BUCKET=memoria-backups
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# --- Behavior toggles ---
WRITE_THROUGH_CACHE=true    # populate Redis on every write
AUTO_BACKUP_ON_WRITE=false  # create local backup on every write (heavy)
LOG_LEVEL=INFO