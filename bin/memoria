#!/usr/bin/env python3
"""memoria -- CLI entry point.

Usage:
    memoria doctor                   # health check
    memoria set <key> <json-value>   # store a memory
    memoria get <key>                # retrieve a memory
    memoria search <query>           # FTS5 search
    memoria explain <topic> <decision> [--risk X] [--reward Y]
                                     # record a decision
    memoria backup [local|supabase|r2|all]
                                     # create backup
    memoria restore <source>         # local|local:latest|supabase|r2
    memoria stats                    # performance dashboard
    memoria shell                    # interactive REPL

Environment:
    All credentials via .env file (see .env.example) or real env vars.
"""

import argparse
import json
import sys
from pathlib import Path

# ensure local package is importable when run from anywhere
ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from memoria import Memoria  # noqa: E402


def main() -> int:
    p = argparse.ArgumentParser(prog="memoria", description=__doc__)
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("doctor", help="health check for all layers")
    sub.add_parser("stats", help="performance dashboard")

    s = sub.add_parser("set", help="store a memory")
    s.add_argument("key")
    s.add_argument("value", help="JSON value or plain string")
    s.add_argument("--category", default="general")
    s.add_argument("--tag", action="append", default=[])

    g = sub.add_parser("get", help="retrieve a memory")
    g.add_argument("key")

    d = sub.add_parser("delete", help="delete a memory")
    d.add_argument("key")

    sr = sub.add_parser("search", help="FTS5 search")
    sr.add_argument("query")
    sr.add_argument("--limit", type=int, default=10)

    e = sub.add_parser("explain", help="record a decision explanation")
    e.add_argument("topic")
    e.add_argument("decision")
    e.add_argument("--rationale", required=True)
    e.add_argument("--risk", default="")
    e.add_argument("--reward", default="")
    e.add_argument("--confidence", type=float, default=0.5)

    b = sub.add_parser("backup", help="backup to a layer")
    b.add_argument("target", nargs="?", default="local",
                   choices=["local", "supabase", "r2", "all"])

    rs = sub.add_parser("restore", help="restore from a layer")
    rs.add_argument("source",
                    help="local <path> | local:latest | supabase | r2")
    rs.add_argument("--mode", choices=["merge", "replace"], default="merge")

    sub.add_parser("shell", help="interactive REPL")

    args = p.parse_args()
    m = Memoria()
    return _dispatch(m, args)


def _dispatch(m: Memoria, args: argparse.Namespace) -> int:
    if args.cmd == "doctor":
        print(json.dumps(m.doctor.run(), indent=2, default=str))
        return 0
    if args.cmd == "stats":
        print(json.dumps(m.stats(), indent=2, default=str))
        return 0
    if args.cmd == "set":
        try:
            value = json.loads(args.value)
        except json.JSONDecodeError:
            value = args.value
        mid = m.set(args.key, value, category=args.category, tags=args.tag)
        print(json.dumps({"ok": True, "id": mid, "key": args.key}, indent=2))
        return 0
    if args.cmd == "get":
        v = m.get(args.key)
        print(json.dumps(v, indent=2, default=str) if v else "(not found)")
        return 0 if v else 1
    if args.cmd == "delete":
        ok = m.delete(args.key)
        print(json.dumps({"ok": ok, "key": args.key}, indent=2))
        return 0 if ok else 1
    if args.cmd == "search":
        rows = m.search(args.query, limit=args.limit)
        print(json.dumps(rows, indent=2, default=str))
        return 0
    if args.cmd == "explain":
        eid = m.explain(
            topic=args.topic, decision=args.decision,
            rationale=args.rationale, risk=args.risk,
            reward=args.reward, confidence=args.confidence,
        )
        print(json.dumps({"ok": True, "id": eid, "topic": args.topic}, indent=2))
        return 0
    if args.cmd == "backup":
        if args.target == "local":
            out = m.backup.local()
        elif args.target == "supabase":
            out = m.backup.supabase()
        elif args.target == "r2":
            out = m.backup.r2()
        else:
            out = m.backup.all()
        print(json.dumps(out, indent=2, default=str))
        return 0 if (out.get("ok", True) if isinstance(out, dict) else True) else 1
    if args.cmd == "restore":
        if args.source == "local:latest":
            out = m.restore.latest_local(mode=args.mode)
        elif args.source == "supabase":
            out = m.restore.supabase(mode=args.mode)
        elif args.source == "r2":
            out = m.restore.r2(mode=args.mode)
        elif args.source.startswith("local:"):
            path = args.source.split(":", 1)[1]
            out = m.restore.local(path, mode=args.mode)
        else:
            print("unknown restore source", file=sys.stderr)
            return 2
        print(json.dumps(out, indent=2, default=str))
        return 0 if out.get("ok") else 1
    if args.cmd == "shell":
        return _repl(m)
    return 2


def _repl(m: Memoria) -> int:
    print("Memoria REPL. Type 'help' or 'quit'.")
    while True:
        try:
            line = input("memoria> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return 0
        if not line:
            continue
        if line in ("quit", "exit"):
            return 0
        if line == "help":
            print("commands: doctor, stats, list, get <key>, search <q>, backup, restore")
            continue
        parts = line.split(maxsplit=1)
        cmd = parts[0]
        rest = parts[1] if len(parts) > 1 else ""
        if cmd == "doctor":
            print(json.dumps(m.doctor.run(), indent=2, default=str))
        elif cmd == "stats":
            print(json.dumps(m.stats(), indent=2, default=str))
        elif cmd == "list":
            for k in m.list_keys(limit=50):
                print(k)
        elif cmd == "get" and rest:
            print(json.dumps(m.get(rest), indent=2, default=str))
        elif cmd == "search" and rest:
            print(json.dumps(m.search(rest, limit=10), indent=2, default=str))
        elif cmd == "backup":
            print(json.dumps(m.backup.all(), indent=2, default=str))
        elif cmd == "restore":
            print(json.dumps(m.restore.latest_local(), indent=2, default=str))
        else:
            print(f"unknown command: {cmd}")
    return 0


if __name__ == "__main__":
    sys.exit(main())